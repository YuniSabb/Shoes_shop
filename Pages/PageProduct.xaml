<Page x:Class="Shoes_shop.Pages.PageProduct"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Shoes_shop.Pages"
      mc:Ignorable="d"
      d:DesignHeight="700"
      d:DesignWidth="1200"
      Title="PageProduct"
      Background="#F5F5F5">

    <Page.Resources>
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#00FA9A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Width" Value="74"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#00FA9A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#00FA9A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#00FA9A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="#7FFF00"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#7FFF00"
                CornerRadius="12"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Назад"
                        Width="110"
                        Style="{StaticResource TopButtonStyle}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Click="BtnBack_Click"
                        Background="#00FA9A"/>

                <TextBlock Grid.Column="1"
                           Text="Список товаров"
                           FontFamily="Times New Roman"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="Black"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,15,0,15"
                Background="White"
                BorderBrush="#7FFF00"
                BorderThickness="2"
                CornerRadius="12"
                Padding="14">

            <Grid x:Name="SpControls" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TbSearch"
                         Grid.Column="0"
                         Height="36"
                         VerticalAlignment="Center"
                         Style="{StaticResource FilterTextBoxStyle}"
                         TextChanged="TbSearch_TextChanged"
                         ToolTip="Поиск"/>

                <ComboBox x:Name="CbSupplier"
                          Grid.Column="2"
                          Height="36"
                          VerticalAlignment="Center"
                          Style="{StaticResource FilterComboBoxStyle}"
                          SelectionChanged="CbSupplier_SelectionChanged"
                          SelectedIndex="-1"/>

                <ComboBox x:Name="CbSort"
                          Grid.Column="4"
                          Height="36"
                          VerticalAlignment="Center"
                          Style="{StaticResource FilterComboBoxStyle}"
                          SelectionChanged="CbSort_SelectionChanged">
                    <ComboBoxItem Content="По количеству (возр.)" IsSelected="True"/>
                    <ComboBoxItem Content="По количеству (убыв.)"/>
                </ComboBox>

                <Button x:Name="BtnAddProduct"
                        Grid.Column="6"
                        Content="Добавить"
                        Width="130"
                        Height="36"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Style="{StaticResource TopButtonStyle}"
                        Click="BtnAddProduct_Click"
                        Visibility="Collapsed"
                        Background="#00FA9A"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#7FFF00"
                BorderThickness="2"
                CornerRadius="12"
                Padding="12">

            <ListView x:Name="LvProducts"
                      SelectionChanged="LvProducts_SelectionChanged">

                <ListView.View>
                    <GridView>

                        <GridViewColumn Header="Фото" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Image Source="{Binding PhotoPath}"
                                               Width="80"
                                               Height="60"
                                               Stretch="Uniform"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Артикул" DisplayMemberBinding="{Binding Article}" Width="100"/>
                        <GridViewColumn Header="Наименование" DisplayMemberBinding="{Binding ProductNamesDict.NameValue}" Width="150"/>
                        <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding ProductCategories.CategoryName}" Width="120"/>
                        <GridViewColumn Header="Производитель" DisplayMemberBinding="{Binding Manufacturers.ManufacturerName}" Width="120"/>
                        <GridViewColumn Header="Поставщик" DisplayMemberBinding="{Binding Suppliers.SupplierName}" Width="120"/>

                        <GridViewColumn Header="Цена" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:F2} ₽}"
                                               Foreground="Black"
                                               VerticalAlignment="Center"
                                               Margin="4"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Скидка %" DisplayMemberBinding="{Binding DiscountPercent}" Width="85"/>
                        <GridViewColumn Header="На складе" DisplayMemberBinding="{Binding StockQuantity}" Width="90"/>
                        <GridViewColumn Header="Ед. изм." DisplayMemberBinding="{Binding Unit}" Width="85"/>

                        <GridViewColumn x:Name="ColDelete" Header="Действие" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Удалить"
                                            Style="{StaticResource DeleteButtonStyle}"
                                            Click="BtnDeleteProduct_Click"
                                            Tag="{Binding Article}"
                                            ToolTip="Удалить товар"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
    </Grid>
</Page>