<Page x:Class="Shoes_shop.Pages.PageEditOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Shoes_shop.Pages"
      mc:Ignorable="d"
      d:DesignHeight="650" d:DesignWidth="900"
      Title="PageEditOrder"
      Background="#F5F5F5">

    <Page.Resources>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="TextBoxStyleSimple" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#00FA9A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

        <Style x:Key="ComboBoxStyleSimple" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#00FA9A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="DatePickerStyleSimple" TargetType="DatePicker">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#00FA9A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
        </Style>

        <Style x:Key="ButtonStyleSimple" TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#7FFF00"
                CornerRadius="12"
                Padding="15">
            <TextBlock Text="Редактирование заказа"
                       FontFamily="Times New Roman"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="Black"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="0,15,0,15"
                      VerticalScrollBarVisibility="Auto">
            <Border Background="White"
                    BorderBrush="#7FFF00"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Основные данные"
                                   FontFamily="Times New Roman"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="№ заказа" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TbOrderNumber"
                                 Style="{StaticResource TextBoxStyleSimple}"
                                 Background="#F5F5F5"/>

                        <TextBlock Text="Дата заказа" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="DpOrderDate"
                                    Style="{StaticResource DatePickerStyleSimple}"/>

                        <TextBlock Text="Дата выдачи" Style="{StaticResource LabelStyle}"/>
                        <DatePicker x:Name="DpDeliveryDate"
                                    Style="{StaticResource DatePickerStyleSimple}"/>

                        <TextBlock Text="Код выдачи" Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="TbPickupCode"
                                 Style="{StaticResource TextBoxStyleSimple}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Дополнительная информация"
                                   FontFamily="Times New Roman"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="Black"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Пункт выдачи" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CbPickupPoint"
                                  Style="{StaticResource ComboBoxStyleSimple}"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Times New Roman">
                                        <Run Text="{Binding PostalCode}"/>
                                        <Run Text=", г. "/>
                                        <Run Text="{Binding City}"/>
                                        <Run Text=", ул. "/>
                                        <Run Text="{Binding Street}"/>
                                        <Run Text=", д. "/>
                                        <Run Text="{Binding House}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Клиент" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CbCustomer"
                                  Style="{StaticResource ComboBoxStyleSimple}"
                                  SelectedValuePath="Id">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock FontFamily="Times New Roman">
                                        <Run Text="{Binding LastName}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding FirstName}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding MiddleName}"/>
                                    </TextBlock>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <TextBlock Text="Статус" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="CbStatus"
                                  Style="{StaticResource ComboBoxStyleSimple}"
                                  SelectedValuePath="Id"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#7FFF00"
                BorderThickness="2"
                CornerRadius="12"
                Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Проверьте данные заказа перед сохранением"
                           FontFamily="Times New Roman"
                           FontSize="15"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="Black"/>

                <Button Grid.Column="1"
                        Content="Отмена"
                        Background="#7FFF00"
                        Style="{StaticResource ButtonStyleSimple}"
                        Click="BtnCancel_Click"/>

                <Button Grid.Column="3"
                        x:Name="BtnSave"
                        Content="Сохранить"
                        Background="#00FA9A"
                        Style="{StaticResource ButtonStyleSimple}"
                        Click="BtnSave_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>